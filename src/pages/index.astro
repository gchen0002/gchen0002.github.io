---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Guanying Chen">
  <div class="min-h-screen bg-luxuryBase text-luxuryDark font-organicBody selection:bg-luxuryDark selection:text-luxuryBase relative">

    {/* Hero — Name */}
    <main class="px-8 pt-20 pb-20 max-w-6xl mx-auto">
      <div class="mb-6 flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <div>
          <h1 class="font-organic text-6xl md:text-8xl leading-none font-light tracking-tight" style="font-variation-settings: 'SOFT' 40;">
            Guanying<br/><span class="italic">Chen</span>
          </h1>
          <p class="mt-4 text-sm tracking-widest uppercase opacity-40">
            Software Developer based in Los Angeles.
          </p>
        </div>
        <a href="/resume.pdf" download class="px-10 py-4 bg-luxuryDark text-luxuryBase text-[11px] tracking-[0.2em] uppercase hover:bg-black transition-colors duration-300 shrink-0 w-max">
          Résumé ↓
        </a>
      </div>

      {/* Skills */}
      <div class="mt-10 pt-6 border-t border-black/10 grid grid-cols-2 md:grid-cols-4 gap-6">
        <div>
          <div class="text-[10px] tracking-[0.2em] uppercase opacity-30 mb-2">Languages</div>
          <div class="text-xs leading-relaxed opacity-50">Java<br/>Python<br/>C++<br/>TypeScript<br/>HTML/CSS<br/>SQL</div>
        </div>
        <div>
          <div class="text-[10px] tracking-[0.2em] uppercase opacity-30 mb-2">Frameworks</div>
          <div class="text-xs leading-relaxed opacity-50">Next.js<br/>React<br/>Tailwind CSS<br/>FastAPI<br/>Express.js</div>
        </div>
        <div>
          <div class="text-[10px] tracking-[0.2em] uppercase opacity-30 mb-2">Cloud</div>
          <div class="text-xs leading-relaxed opacity-50">AWS Lambda<br/>S3<br/>Google Cloud<br/>Cloudflare<br/>Supabase</div>
        </div>
        <div>
          <div class="text-[10px] tracking-[0.2em] uppercase opacity-30 mb-2">Tools</div>
          <div class="text-xs leading-relaxed opacity-50">Docker<br/>Git<br/>SQLite<br/>Convex<br/>Clerk<br/>Mapbox</div>
        </div>
      </div>

      {/* Projects */}
      <div class="mt-14 pt-6 border-t border-black/10">
        <div class="flex justify-between items-end mb-8">
          <h2 class="font-organic text-2xl italic" style="font-variation-settings: 'SOFT' 60;">Projects</h2>
          <div class="text-[10px] tracking-widest uppercase opacity-30">24—26</div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <!-- EchoMap -->
          <a href="https://devpost.com/software/x-ampe2d?ref_content=user-portfolio&ref_feature=in_progress" target="_blank" class="group block">
            <div class="w-full aspect-square bg-black/[0.04] border border-black/5 overflow-hidden relative hover:border-black/15 transition-colors duration-300">
              <img src="/echomap.png" alt="EchoMap" class="w-full h-full object-cover" />
            </div>
            <div class="mt-3 flex justify-between items-baseline">
              <h3 class="text-sm font-medium tracking-wide">EchoMap</h3>
              <span class="text-[10px] tracking-wider opacity-30">2026</span>
            </div>
            <div class="text-[10px] tracking-wider opacity-30 mt-0.5">TypeScript · Next.js · Convex · Mapbox</div>
          </a>

          <!-- Distributed Log System -->
          <a href="https://github.com/gchen0002/Log-Aggregation-System" target="_blank" class="group block">
            <div class="w-full aspect-square bg-black/[0.04] border border-black/5 overflow-hidden relative hover:border-black/15 transition-colors duration-300">
              <div class="absolute inset-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="opacity-10 group-hover:opacity-25 transition-opacity"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </div>
            </div>
            <div class="mt-3 flex justify-between items-baseline">
              <h3 class="text-sm font-medium tracking-wide">Log Aggregation</h3>
              <span class="text-[10px] tracking-wider opacity-30">2026</span>
            </div>
            <div class="text-[10px] tracking-wider opacity-30 mt-0.5">C++17 · Python · SQLite · Docker</div>
          </a>

          <!-- RitoEsports -->
          <a href="https://chromewebstore.google.com/detail/ritoesports-tracker/eldpjindebiejpnpclddndcnmefbbooi?authuser=0&hl=en" target="_blank" class="group block">
            <div class="w-full aspect-square bg-black/[0.04] border border-black/5 overflow-hidden relative hover:border-black/15 transition-colors duration-300">
              <div class="absolute inset-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="opacity-10 group-hover:opacity-25 transition-opacity"><circle cx="12" cy="12" r="4.5" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M12 2a10 10 0 0 1 8.66 5h-5.91a5 5 0 0 0-5.5 0H3.34A10 10 0 0 1 12 2zM2 12a10 10 0 0 0 5 8.66l2.95-5.12a5 5 0 0 1-2.75-4.78L2.05 10.5A10 10 0 0 0 2 12zm15.2 1.24L14.25 18.4A10 10 0 0 0 22 12a10 10 0 0 0-.54-3.24l-5.12 2.96a5 5 0 0 1 .86 1.52z"/></svg>
              </div>
            </div>
            <div class="mt-3 flex justify-between items-baseline">
              <h3 class="text-sm font-medium tracking-wide">RitoEsports Tracker</h3>
              <span class="text-[10px] tracking-wider opacity-30">2025</span>
            </div>
            <div class="text-[10px] tracking-wider opacity-30 mt-0.5">TypeScript · AWS Lambda · S3</div>
          </a>

          <!-- Gene Analysis -->
          <a href="https://github.com/gchen0002/Exons" target="_blank" class="group block">
            <div class="w-full aspect-square bg-black/[0.04] border border-black/5 overflow-hidden relative hover:border-black/15 transition-colors duration-300">
              <div class="absolute inset-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="opacity-10 group-hover:opacity-25 transition-opacity"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </div>
            </div>
            <div class="mt-3 flex justify-between items-baseline">
              <h3 class="text-sm font-medium tracking-wide">Gene Analysis Tool</h3>
              <span class="text-[10px] tracking-wider opacity-30">2024</span>
            </div>
            <div class="text-[10px] tracking-wider opacity-30 mt-0.5">Java · Algorithms</div>
          </a>
        </div>
      </div>
    </main>

    {/* Footer */}
    <footer class="px-8 py-6 border-t border-black/5 flex justify-between text-[10px] tracking-widest uppercase opacity-30">
      <div>Los Angeles, CA</div>
      <div>© 2026 Guanying Chen</div>
    </footer>
  </div>
</Layout>
